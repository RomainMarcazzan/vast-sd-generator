// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model GenerationJob {
  id             String         @id @default(cuid())
  prompt         String
  negativePrompt String?
  width          Int            @default(1024)
  height         Int            @default(1024)
  steps          Int            @default(20)
  cfgScale       Float          @default(7)
  sampler        String         @default("euler")
  scheduler      String         @default("normal")
  seed           BigInt?
  denoiseStrength Float?        // null = txt2img, set for img2img
  sourceImagePath String?       // source image path for img2img
  mediaType      MediaType      @default(IMAGE)
  status         JobStatus      @default(PENDING)
  vastInstanceId String?
  errorMessage   String?
  image          GeneratedImage?
  video          GeneratedVideo?
  instanceId     String?        // Référence à une instance persistante (optionnel)
  instance       VastInstance?  @relation(fields: [instanceId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

enum MediaType {
  IMAGE
  VIDEO
}

enum JobStatus {
  PENDING
  PROVISIONING
  GENERATING
  COMPLETED
  FAILED
}

model GeneratedImage {
  id        String        @id @default(cuid())
  filename  String        @unique
  path      String
  sizeBytes Int
  width     Int
  height    Int
  jobId     String        @unique
  job       GenerationJob @relation(fields: [jobId], references: [id])
  createdAt DateTime      @default(now())
}

model GeneratedVideo {
  id        String        @id @default(cuid())
  filename  String        @unique
  path      String
  sizeBytes Int
  width     Int
  height    Int
  fps       Int           @default(16)
  frames    Int           @default(81)
  jobId     String        @unique
  job       GenerationJob @relation(fields: [jobId], references: [id])
  createdAt DateTime      @default(now())
}

model VastInstance {
  id             String          @id @default(cuid())
  vastInstanceId String          @unique // ID de l'instance chez Vast.ai
  type           InstanceType    @default(IMAGE)
  status         InstanceStatus  @default(PROVISIONING)
  host           String?         // IP publique
  port           String?         // Port mappé
  gpuName        String?         // Nom du GPU
  costPerHour    Float?          // Coût horaire
  lastUsedAt     DateTime        @default(now())
  expiresAt      DateTime        // Date d'expiration auto (timeout)
  jobs           GenerationJob[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum InstanceType {
  IMAGE  // SDXL — 12GB VRAM min
  VIDEO  // Wan 2.1 — 16GB VRAM min
}

enum InstanceStatus {
  PROVISIONING
  RUNNING
  DESTROYED
}
