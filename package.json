{
  "name": "vast-sd-generator",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "precommit": "npm run check && npm run typecheck",
    "test": "npm run test:db:start && npm run test:local && npm run test:db:stop",
    "test:db:start": "docker compose -f docker-compose.test.yml up test-db -d --wait",
    "test:db:stop": "docker compose -f docker-compose.test.yml down",
    "test:local": "export DATABASE_URL=postgresql://test:test@localhost:5433/test_db && export VAST_AI_API_KEY=test-api-key && vitest run",
    "test:watch": "export DATABASE_URL=postgresql://test:test@localhost:5433/test_db && export VAST_AI_API_KEY=test-api-key && vitest",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint ."
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "dotenv": "^17.2.3",
    "hono": "^4.11.5",
    "pg": "^8.17.2",
    "prisma": "^7.3.0",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/node": "^20.11.17",
    "@types/pg": "^8.16.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.3"
  }
}
