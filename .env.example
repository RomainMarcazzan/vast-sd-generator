# Environment variables for development
POSTGRES_USER=hono
POSTGRES_PASSWORD=hono123
POSTGRES_DB=hono_db
DATABASE_URL=postgresql://hono:hono123@localhost:5432/hono_db

# Server
PORT=3000
NODE_ENV=development

# CORS configuration (default: * for development)
CORS_ORIGIN=*

# Swagger Basic Auth (default: admin/admin for development)
SWAGGER_USER=admin
SWAGGER_PASSWORD=admin

# Server URL for OpenAPI spec (default: http://localhost:3000)
SERVER_URL=http://localhost:3000

# Grafana credentials (default: admin/admin)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Vast.ai API key (https://cloud.vast.ai/account)
VAST_AI_API_KEY=

# Path where generated images are stored on disk
# On the RPi this will be a path on the USB drive
IMAGES_STORAGE_PATH=/data/images

