{
  "name": "vast-sd-generator",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "precommit": "npm run check && npm run typecheck",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint ."
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "dotenv": "^17.2.3",
    "hono": "^4.11.5",
    "pg": "^8.17.2",
    "prisma": "^7.3.0",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/node": "^20.11.17",
    "@types/pg": "^8.16.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
